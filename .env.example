# API Keys — get yours at https://openrouter.ai/keys
# Production: set this in .env on the server; the UI cannot save keys when NODE_ENV=production
# (optional escape hatch: ALLOW_UI_API_KEY=true — not recommended)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Server (5000 is often used by macOS AirPlay on Mac)
PORT=5001

# Python executable (macOS/Linux usually python3, not python)
PYTHON_PATH=python3

# Application settings
DEBUG=True
LOG_LEVEL=INFO

# Model settings
DEFAULT_MODEL=openrouter/free
TEMPERATURE=0.7
MAX_TOKENS=1000

# NLTK data is not in git — run locally: npm run setup:nltk
# Optional override:
# NLTK_DATA=./nltk_data

# Public URL of the app (OpenRouter HTTP-Referer, CORS). On Render, RENDER_EXTERNAL_URL
# is set for you; you can override with a custom domain:
# FRONTEND_URL=https://scribe.example.com
